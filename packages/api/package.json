{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "main": "./",
  "scripts": {
    "start:node": "node ./dist/index.js",
    "start:node-w": "node ./dist/index.js --watch",
    "dev": "bun --watch ./index.ts ",
    "start:bun": "bun ./dist/index.js",
    "build": "bun build ./index.ts --outdir ./dist --target node --minify",
    "build:compile": "bun build ./index.ts --target node --compile",
    "build:watch": "bun build ./index.ts --outdir ./dist --target node --minify --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@likkida/shared": "workspace: *",
    "@supabase/supabase-js": "^2.88.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "body-parser": "^2.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "supabase": "^2.72.8"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}